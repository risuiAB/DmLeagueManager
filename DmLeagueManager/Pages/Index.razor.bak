@page "/"
@inject SeasonService SeasonService
@inject TournamentService TournamentService
@inject PlayerService PlayerService
@inject MatchService MatchService
@inject DeckService DeckService

<PageTitle>順位表 - DM League Manager</PageTitle>

@if (loading)
{
    <div class="loading">読み込み中...</div>
}
else if (activeSeason == null)
{
    <div class="empty-state">
        <p>アクティブなシーズンがありません</p>
        <a href="admin" class="btn-primary">シーズンを作成する</a>
    </div>
}
else
{
    <!-- シーズン総合順位 -->
    <div class="section-title">@activeSeason.Name 総合順位</div>
    <div class="standings-card" style="margin-bottom:20px">
        <div class="standings-header">
            <div class="standings-title">シーズン累計</div>
            <div class="match-count">@pastTournaments.Count 大会終了</div>
        </div>
        @if (!seasonRankings.Any())
        {
            <div style="padding:16px; text-align:center; color:var(--text-dim); font-size:13px;">大会結果がまだありません</div>
        }
        else
        {
            int sRank = 1;
            @foreach (var r in seasonRankings)
            {
                string rankClass = sRank switch { 1 => "rank-num gold", 2 => "rank-num silver", 3 => "rank-num bronze", _ => "rank-num" };
                <div class="player-row @(sRank == 1 ? "top1" : "")">
                    <div class="@rankClass">@sRank</div>
                    <div class="player-info">
                        <div class="player-name">@r.Player.Name</div>
                        <div style="font-size:11px; color:var(--text-dim)">@r.TournamentCount 大会参加</div>
                    </div>
                    <div class="player-stats">
                        <span class="text-win">@r.TotalWins 勝</span> / <span class="text-lose">@r.TotalLoses 敗</span>
                    </div>
                    <div class="player-points">@r.TotalPoints<span class="points-label">pt</span></div>
                </div>
                sRank++;
            }
        }
    </div>

    <!-- 現在の大会 -->
    @if (activeTournament != null)
    {
        @if (recentElimination != null)
        {
            <div class="alert-banner">
                <span class="alert-icon">💀</span>
                <span><strong>@recentElimination.Player?.Name</strong> が脱落しました！（@recentElimination.Rank 位）</span>
            </div>
        }

        <div class="season-summary">
            <div class="summary-item">
                <div class="summary-value">@totalMatches</div>
                <div class="summary-label">試合数</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@standings.Count</div>
                <div class="summary-label">参加者</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@activeTournament.DeckCount デッキ</div>
                <div class="summary-label">デッキ数</div>
            </div>
        </div>

        <div class="section-title">@activeTournament.Name（進行中）</div>
        <div class="standings-card">
            <div class="standings-header">
                <div class="standings-title">大会順位</div>
                <div class="match-count">@totalMatches 試合</div>
            </div>
            @{ int displayRank = 1; }
            @foreach (var sp in standings)
            {
                string rowClass = displayRank == 1 ? "player-row top1" : sp.IsEliminated ? "player-row eliminated" : "player-row";
                string rankClass = displayRank switch { 1 => "rank-num gold", 2 => "rank-num silver", 3 => "rank-num bronze", _ => "rank-num" };
                <div class="@rowClass">
                    <div class="@rankClass">@displayRank</div>
                    <div class="player-info">
                        <div class="player-name">@sp.Player?.Name</div>
                        <div class="deck-pips">
                            @for (int i = 0; i < sp.RemainingDecks; i++) { <div class="pip"></div> }
                            @for (int i = sp.RemainingDecks; i < activeTournament.DeckCount; i++) { <div class="pip lost"></div> }
                        </div>
                    </div>
                    <div class="player-stats">
                        残@(sp.RemainingDecks)デッキ<br />
                        <span class="text-win">@sp.WinCount 勝</span> / <span class="text-lose">@sp.LoseCount 敗</span>
                    </div>
                    <div class="player-points">@sp.TotalPoints<span class="points-label">pt</span></div>
                </div>
                displayRank++;
            }
        </div>
    }
    else
    {
        <div class="empty-state" style="padding:24px; background:var(--surface); border:1px solid var(--border); border-radius:12px;">
            <p style="color:var(--text-dim)">進行中の大会はありません</p>
            <a href="admin" style="color:var(--accent); font-size:13px;">大会を作成する →</a>
        </div>
    }
}

<!-- 試合入力FAB -->
@if (activeTournament != null && activeTournament.IsActive && standings.Count(x=>!x.IsEliminated) > 1)
{
    <button class="fab" @onclick="OpenModal">⚔️ 試合結果を入力</button>
}

<!-- 試合入力モーダル -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModalOutside">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-handle"></div>
            <div class="modal-title">⚔️ 試合結果の入力</div>

            <div class="form-label">🏆 勝者</div>
            <div class="player-buttons" style="margin-bottom:16px">
                @foreach (var sp in standings.Where(s => !s.IsEliminated))
                {
                    <button class="player-select-btn @(selectedWinnerId == sp.PlayerId ? "selected-win" : "")"
                            @onclick="() => SelectWinner(sp)">
                        @sp.Player?.Name
                    </button>
                }
            </div>

            @if (selectedWinnerId > 0)
            {
                <div class="form-label">🃏 勝者のデッキ</div>
                <DeckSelector SeasonDecks="@winnerSeasonDecks" AllDecks="@winnerAllDecks"
                    SelectedDeckId="@selectedWinnerDeckId"
                    ShowAll = "false"
                    OnDeckSelected="SetWinnerDeckId" OnNewDeckName="SetWinnerNewDeckName"
                    OnDeckAddedToSeason="AddToWinnerSeasonDecks" />
            }

            <div class="form-label" style="margin-top:16px">💀 敗者</div>
            <div class="player-buttons" style="margin-bottom:16px">
                @foreach (var sp in standings.Where(s => !s.IsEliminated && s.PlayerId != selectedWinnerId))
                {
                    <button class="player-select-btn @(selectedLoserId == sp.PlayerId ? "selected-lose" : "")"
                            @onclick="() => SelectLoser(sp)">@sp.Player?.Name</button>
                }
            </div>

            @if (selectedLoserId > 0)
            {
                <div class="form-label">💀 敗者のデッキ（消滅します）</div>
                <DeckSelector SeasonDecks="@loserSeasonDecks" AllDecks="@loserAllDecks"
                    SelectedDeckId="@selectedLostDeckId"
                    ShowAll="false"
                    OnDeckSelected="SetLostDeckId" OnNewDeckName="SetLoserNewDeckName"
                    OnDeckAddedToSeason="AddToLoserSeasonDecks" />
            }
            <div class="form-label" style="margin-top:16px">⚡ 先攻</div>
            <div style="background:var(--surface2); border:1px solid var(--border); border-radius:8px;
                padding:12px 14px; display:flex; align-items:center; gap:10px; margin-bottom:16px;">
                <input type="checkbox" id="firstPlayerCheck"
                       checked="@winnerIsFirst"
                       @onchange="e => winnerIsFirst = (bool)e.Value!"
                       style="width:18px; height:18px; cursor:pointer;" />
                <label for="firstPlayerCheck" style="font-size:13px; cursor:pointer;">
                    @if (selectedWinnerId > 0)
                    {
                        <span>勝者（@(standings.FirstOrDefault(s => s.PlayerId == selectedWinnerId)?.Player?.Name ?? "？")）が先攻</span>
                    }
                    else
                    {
                        <span>勝者が先攻</span>
                    }
                </label>
            </div>
            @if (errorMessage != null) { <div class="error-msg">⚠️ @errorMessage</div> }
            <div class="form-label" style="margin-top:16px">📝 メモ（任意）</div>
            <textarea class="text-input" @bind="matchMemo" placeholder="試合のメモを入力..."
                    style="resize:vertical; min-height:60px;"></textarea>
            <button class="submit-btn" @onclick="SubmitMatch" disabled="@submitting">
                @(submitting ? "登録中..." : "✅ 結果を確定する")
            </button>
        </div>
    </div>
}

@code {
    private Season? activeSeason;
    private Tournament? activeTournament;
    private List<Tournament> pastTournaments = new();
    private List<SeasonPlayer> standings = new();
    private List<SeasonRanking> seasonRankings = new();
    private int totalMatches = 0;
    private bool loading = true;
    private SeasonPlayer? recentElimination;

    private bool showModal = false;
    private int selectedWinnerId = 0;
    private int selectedWinnerSeasonPlayerId = 0;
    private int selectedLoserId = 0;
    private int selectedLoserSeasonPlayerId = 0;
    private int selectedWinnerDeckId = 0;
    private string winnerNewDeckName = "";
    private List<Deck> winnerSeasonDecks = new();
    private List<Deck> winnerAllDecks = new();
    private int selectedLostDeckId = 0;
    private string loserNewDeckName = "";
    private List<Deck> loserSeasonDecks = new();
    private List<Deck> loserAllDecks = new();
    private string? errorMessage;
    private bool submitting = false;
    private string matchMemo = "";
    private bool winnerIsFirst = true; // デフォルトは勝者が先攻

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        loading = true;
        activeSeason = await SeasonService.GetActiveAsync();
        if (activeSeason != null)
        {
            var tournaments = await TournamentService.GetBySeasonAsync(activeSeason.Id);
            activeTournament = tournaments.FirstOrDefault(t => t.IsActive);
            pastTournaments = tournaments.Where(t => !t.IsActive).ToList();
            seasonRankings = await PlayerService.GetSeasonRankingsAsync(activeSeason.Id);

            if (activeTournament != null)
            {
                standings = await PlayerService.GetTournamentStandingsAsync(activeTournament.Id);
                var matches = await MatchService.GetTournamentMatchesAsync(activeTournament.Id);
                totalMatches = matches.Count;
                recentElimination = standings.Where(sp => sp.IsEliminated)
                    .OrderByDescending(sp => sp.Rank).FirstOrDefault();
            }
        }
        loading = false;
    }

    private void OpenModal()
    {
        showModal = true;
        selectedWinnerId = 0; selectedWinnerSeasonPlayerId = 0;
        selectedLoserId = 0; selectedLoserSeasonPlayerId = 0;
        selectedWinnerDeckId = 0; winnerNewDeckName = "";
        selectedLostDeckId = 0; loserNewDeckName = "";
        winnerSeasonDecks.Clear(); winnerAllDecks.Clear();
        loserSeasonDecks.Clear(); loserAllDecks.Clear();
        matchMemo = "";
        winnerIsFirst = true;
        errorMessage = null;
    }

    private void CloseModalOutside() => showModal = false;

    private async Task SelectWinner(SeasonPlayer sp)
    {
        selectedWinnerId = sp.PlayerId; selectedWinnerSeasonPlayerId = sp.Id;
        selectedWinnerDeckId = 0; winnerNewDeckName = "";
        winnerSeasonDecks = await DeckService.GetBySeasonPlayerAsync(sp.Id);
        winnerAllDecks = await DeckService.GetAllByPlayerAsync(sp.PlayerId);
    }

    private async Task SelectLoser(SeasonPlayer sp)
    {
        selectedLoserId = sp.PlayerId; selectedLoserSeasonPlayerId = sp.Id;
        selectedLostDeckId = 0; loserNewDeckName = "";
        loserSeasonDecks = await DeckService.GetBySeasonPlayerAsync(sp.Id);
        loserAllDecks = await DeckService.GetAllByPlayerAsync(sp.PlayerId);
    }

    private void SetWinnerDeckId(int id) => selectedWinnerDeckId = id;
    private void SetWinnerNewDeckName(string name) => winnerNewDeckName = name;
    private void SetLostDeckId(int id) => selectedLostDeckId = id;
    private void SetLoserNewDeckName(string name) => loserNewDeckName = name;

    private void AddToWinnerSeasonDecks(Deck deck)
    {
        if (!winnerSeasonDecks.Any(d => d.Id == deck.Id))
            winnerSeasonDecks.Add(deck);
    }

    private void AddToLoserSeasonDecks(Deck deck)
    {
        if (!loserSeasonDecks.Any(d => d.Id == deck.Id))
            loserSeasonDecks.Add(deck);
    }

    private async Task SubmitMatch()
    {
        errorMessage = null;
        if (selectedWinnerId == 0) { errorMessage = "勝者を選択してください"; return; }
        if (selectedWinnerDeckId == 0 && string.IsNullOrWhiteSpace(winnerNewDeckName)) { errorMessage = "勝者のデッキを選択または入力してください"; return; }
        if (selectedLoserId == 0) { errorMessage = "敗者を選択してください"; return; }
        if (selectedLostDeckId == 0 && string.IsNullOrWhiteSpace(loserNewDeckName)) { errorMessage = "敗者のデッキを選択または入力してください"; return; }

        submitting = true;
        try
        {
            int winnerDeckId = selectedWinnerDeckId;
            if (winnerDeckId == 0)
            {
                var deck = await DeckService.RegisterDeckAsync(
                    selectedWinnerSeasonPlayerId, selectedWinnerId, winnerNewDeckName);
                winnerDeckId = deck.Id;
            }
            else
            {
                // 全履歴から選択した場合、今大会に紐づけ登録
                var existingDecks = await DeckService.GetBySeasonPlayerAsync(selectedWinnerSeasonPlayerId);
                if (!existingDecks.Any(d => d.Id == winnerDeckId))
                {
                    var selectedDeck = winnerAllDecks.FirstOrDefault(d => d.Id == winnerDeckId);
                    if (selectedDeck != null)
                        await DeckService.RegisterDeckAsync(
                            selectedWinnerSeasonPlayerId, selectedWinnerId, selectedDeck.Name);
                }
            }
            int lostDeckId = selectedLostDeckId;
            if (lostDeckId == 0)
            {
                var lostDecks = await DeckService.GetBySeasonPlayerAsync(selectedLoserSeasonPlayerId);
                var duplicate = lostDecks.FirstOrDefault(d =>
                    !d.IsActive && d.Name == loserNewDeckName.Trim());

                if (duplicate != null)
                {
                    errorMessage = $"「{loserNewDeckName}」はすでに消滅したデッキです";
                    submitting = false;
                    return;
                }

                var deck = await DeckService.RegisterDeckAsync(
                    selectedLoserSeasonPlayerId, selectedLoserId, loserNewDeckName);
                lostDeckId = deck.Id;
            }
            else
            {
                // 全履歴から選択した場合、今大会に紐づけ登録
                var existingDecks = await DeckService.GetBySeasonPlayerAsync(selectedLoserSeasonPlayerId);
                if (!existingDecks.Any(d => d.Id == lostDeckId))
                {
                    var selectedDeck = loserAllDecks.FirstOrDefault(d => d.Id == lostDeckId);
                    if (selectedDeck != null)
                        await DeckService.RegisterDeckAsync(
                            selectedLoserSeasonPlayerId, selectedLoserId, selectedDeck.Name);
                }
            }

            // 先攻プレイヤーID = 勝者が先攻ならwinnerPlayerId、そうでなければloserPlayerId
            int firstPlayerId = winnerIsFirst ? selectedWinnerId : selectedLoserId;

            await MatchService.RecordMatchAsync(
                activeSeason!.Id, activeTournament!.Id,
                selectedWinnerId, selectedLoserId,
                winnerDeckId, lostDeckId,
                firstPlayerId,
                string.IsNullOrWhiteSpace(matchMemo) ? null : matchMemo);

            showModal = false;
            await LoadData();
        }
        catch (Exception ex) { errorMessage = $"エラー: {ex.Message}"; }
        finally { submitting = false; }
    }
}
