@page "/admin"
@inject SeasonService SeasonService
@inject TournamentService TournamentService
@inject PlayerService PlayerService
@inject BannedCardService BannedCardService
@inject Supabase.Client supabase
@inject IJSRuntime JS

<PageTitle>管理 - DM League Manager</PageTitle>

<div class="section-title">⚙️ 管理</div>

<!-- タブ切り替え -->
<div class="player-tabs" style="margin-bottom:16px;">
    <button class="player-tab-btn @(activeTab == "manage" ? "active" : "")"
            @onclick='() => activeTab = "manage"'>⚙️ 管理</button>
    <button class="player-tab-btn @(activeTab == "backup" ? "active" : "")"
            @onclick='() => activeTab = "backup"'>💾 バックアップ</button>
</div>

@if (activeTab == "manage")
{
    <!-- シーズン管理 -->
    <div class="admin-card">
        <div class="admin-card-title">📅 シーズン管理</div>
        @if (activeSeason != null)
        {
            <div class="alert-info">進行中: <strong>@activeSeason.Name</strong></div>
            <div style="margin-top:12px; margin-bottom:12px;">
                <div class="form-label">🏆 順位ごとの勝ち点（カンマ区切り）</div>
                <div style="display:flex; gap:8px;">
                    <input class="text-input" @bind="editRankPoints"
                           style="flex:1; margin-bottom:0;" placeholder="3,1,0" />
                    <button class="btn-primary" @onclick="UpdateRankPoints" style="white-space:nowrap;">更新</button>
                </div>
                <div style="font-size:11px; color:var(--text-dim); margin-top:6px;">
                    現在: @string.Join(", ", activeSeason.RankPointsList.Select((p, i) => $"{i+1}位:{p}pt"))
                </div>
            </div>
            <button class="btn-danger" @onclick="FinishSeason">シーズンを終了する</button>
        }
        else
        {
            <input class="text-input" @bind="newSeasonName" placeholder="シーズン名（例: 2025年シーズン）" />
            <div class="form-label" style="margin-top:8px;">🏆 順位ごとの勝ち点（カンマ区切り）</div>
            <input class="text-input" @bind="newRankPoints" placeholder="3,1,0" />
            <div style="font-size:11px; color:var(--text-dim); margin-bottom:8px;">
                例: 3人なら「3,1,0」、4人なら「4,2,1,0」
            </div>
            <button class="btn-primary" @onclick="CreateSeason"
                    disabled="@string.IsNullOrWhiteSpace(newSeasonName)">
                シーズンを作成
            </button>
        }
    </div>

    <!-- 大会管理 -->
    @if (activeSeason != null)
    {
        <div class="admin-card">
            <div class="admin-card-title">🏆 大会管理</div>
            @if (activeTournament != null)
            {
                <div class="alert-info">進行中: <strong>@activeTournament.Name</strong>（@activeTournament.DeckCount デッキ）</div>
                <button class="btn-danger" @onclick="FinishTournament">大会を終了する</button>
            }
            else
            {
                <input class="text-input" @bind="newTournamentName" placeholder="大会名（例: 第1回大会）" />
                <label class="form-label" style="margin-top:8px">使用デッキ数</label>
                <input class="text-input" type="number" @bind="newTournamentDeckCount" min="1" max="20" />
                <button class="btn-primary" @onclick="CreateTournament"
                        disabled="@string.IsNullOrWhiteSpace(newTournamentName)">
                    大会を作成
                </button>
            }
            @if (pastTournaments.Any())
            {
                <div style="margin-top:16px;">
                    <div class="form-label">過去の大会</div>
                    @foreach (var t in pastTournaments)
                    {
                        <div style="background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:10px 14px; margin-bottom:6px; font-size:13px;">
                            @t.Name <span style="color:var(--text-dim)">（@t.DeckCount デッキ）</span>
                        </div>
                    }
                </div>
            }
        </div>

        @if (activeTournament != null)
        {
            <div class="admin-card">
                <div class="admin-card-title">👤 大会参加登録</div>
                <p class="text-dim" style="font-size:12px; margin-bottom:12px">
                    使用デッキ数: <strong style="color:var(--accent)">@activeTournament.DeckCount デッキ</strong>
                </p>
                <div style="display:flex; flex-direction:column; gap:8px;">
                    @foreach (var p in allPlayers)
                    {
                        bool isJoined = joinedPlayerIds.Contains(p.Id);
                        if (!initialPointsMap.ContainsKey(p.Id))
                            initialPointsMap[p.Id] = 0;
                        <div style="display:flex; align-items:center; justify-content:space-between;
                                    background:var(--surface2); border:1px solid @(isJoined ? "rgba(39,174,96,0.4)" : "var(--border)");
                                    border-radius:8px; padding:12px 14px;">
                            <span style="font-weight:700; color:@(isJoined ? "var(--win)" : "var(--text)")">
                                @(isJoined ? "✅ " : "")@p.Name
                            </span>
                            @if (!isJoined)
                            {
                                <button class="btn-primary" style="padding:6px 14px; font-size:12px;"
                                        @onclick="() => JoinTournament(p.Id)">参加登録</button>
                            }
                            else
                            {
                                <span style="font-size:12px; color:var(--win)">登録済み</span>
                            }
                        </div>
                        @if (!isJoined)
                        {
                            <div style="display:flex; align-items:center; gap:8px;">
                                <span style="font-size:11px; color:var(--text-dim); white-space:nowrap;">初期勝ち点:</span>
                                <input type="number" class="text-input"
                                       style="margin-bottom:0; padding:6px 10px; font-size:13px;"
                                       value="@initialPointsMap[p.Id]"
                                       @oninput="e => initialPointsMap[p.Id] = int.TryParse(e.Value?.ToString(), out var v) ? v : 0" />
                            </div>
                        }
                    }
                </div>
            </div>
        }

        <div class="admin-card">
            <div class="admin-card-title">🚫 禁止カード（@activeSeason.Name）</div>
            @if (bannedCards.Any())
            {
                <div style="display:flex; flex-direction:column; gap:6px; margin-bottom:14px;">
                    @foreach (var card in bannedCards)
                    {
                        <div style="display:flex; align-items:center; justify-content:space-between;
                                    background:rgba(192,57,43,0.08); border:1px solid rgba(192,57,43,0.3);
                                    border-radius:8px; padding:10px 14px;">
                            <span style="font-size:13px; font-weight:700;">🚫 @card.CardName</span>
                            <button @onclick="() => DeleteBannedCard(card.Id)"
                                    style="background:none; border:none; color:var(--text-dim); cursor:pointer; font-size:18px; padding:0 4px; line-height:1;">×</button>
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="font-size:12px; color:var(--text-dim); margin-bottom:14px;">禁止カードはありません</div>
            }
            <div style="display:flex; gap:8px;">
                <input class="text-input" @bind="newCardName" placeholder="カード名を入力" style="flex:1; margin-bottom:0;" />
                <button class="btn-primary" @onclick="AddBannedCard"
                        disabled="@string.IsNullOrWhiteSpace(newCardName)">追加</button>
            </div>
        </div>
    }

    <div class="admin-card">
        <div class="admin-card-title">👤 プレイヤー管理</div>
        <div class="player-list-admin">
            @foreach (var p in allPlayers)
            {
                <div class="player-list-item">@p.Name</div>
            }
        </div>
        <div style="display:flex; gap:8px; margin-top:12px">
            <input class="text-input" @bind="newPlayerName" placeholder="プレイヤー名" style="flex:1; margin-bottom:0;" />
            <button class="btn-primary" @onclick="CreatePlayer"
                    disabled="@string.IsNullOrWhiteSpace(newPlayerName)">追加</button>
        </div>
    </div>
}

@if (activeTab == "backup")
{
    <div class="admin-card">
        <div class="admin-card-title">📤 バックアップ出力</div>
        <p style="font-size:12px; color:var(--text-dim); margin-bottom:12px;">
            全データをJSONファイルとしてダウンロードします。
        </p>
        <button class="btn-primary" @onclick="ExportBackup" disabled="@backupLoading">
            @(backupLoading ? "出力中..." : "📥 JSONダウンロード")
        </button>
    </div>

    <div class="admin-card">
        <div class="admin-card-title">📥 バックアップ復元</div>
        <p style="font-size:12px; color:var(--text-dim); margin-bottom:12px;">
            JSONファイルを選択してデータを復元します。<br />
            ⚠️ 既存データは全て上書きされます。
        </p>
        
        <InputFile OnChange="OnFileSelected" accept=".json"
           style="font-size:13px; color:var(--text); margin-bottom:12px;" />
        @if (importPreview != null)
        {
            <div style="background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:12px; margin-bottom:12px; font-size:12px;">
                <div>👤 プレイヤー: @importPreview.Players.Count 件</div>
                <div>📅 シーズン: @importPreview.Seasons.Count 件</div>
                <div>🏆 大会: @importPreview.Tournaments.Count 件</div>
                <div>🃏 デッキ: @importPreview.Decks.Count 件</div>
                <div>⚔️ 試合: @importPreview.Matches.Count 件</div>
            </div>
            <button class="btn-danger" @onclick="ImportBackup" disabled="@importLoading">
                @(importLoading ? "復元中..." : "⚠️ 復元を実行する")
            </button>
        }
    </div>
}

@if (message != null) { <div class="success-msg">✅ @message</div> }
@if (errorMessage != null) { <div class="error-msg">⚠️ @errorMessage</div> }

@code {
    private string activeTab = "manage";

    private Season? activeSeason;
    private Tournament? activeTournament;
    private List<Tournament> pastTournaments = new();
    private List<Player> allPlayers = new();
    private List<int> joinedPlayerIds = new();
    private List<BannedCard> bannedCards = new();
    private Dictionary<int, int> initialPointsMap = new();

    private string newSeasonName = "";
    private string newRankPoints = "3,1,0";
    private string editRankPoints = "3,1,0";
    private string newTournamentName = "";
    private int newTournamentDeckCount = 6;
    private string newPlayerName = "";
    private string newCardName = "";
    private string? message;
    private string? errorMessage;

    // バックアップ
    private bool backupLoading = false;
    private bool importLoading = false;
    private BackupData? importPreview;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        message = null; errorMessage = null;
        activeSeason = await SeasonService.GetActiveAsync();
        allPlayers = await PlayerService.GetAllAsync();
        if (activeSeason != null)
        {
            editRankPoints = string.Join(",", activeSeason.RankPointsList);
            var tournaments = await TournamentService.GetBySeasonAsync(activeSeason.Id);
            activeTournament = tournaments.FirstOrDefault(t => t.IsActive);
            pastTournaments = tournaments.Where(t => !t.IsActive).ToList();
            if (activeTournament != null)
            {
                var standings = await PlayerService.GetTournamentStandingsAsync(activeTournament.Id);
                joinedPlayerIds = standings.Select(sp => sp.PlayerId).ToList();
            }
            bannedCards = await BannedCardService.GetBySeasonAsync(activeSeason.Id);
        }
    }

    private List<int> ParseRankPoints(string input)
    {
        return input.Split(',')
            .Select(s => int.TryParse(s.Trim(), out var v) ? v : 0)
            .ToList();
    }

    // ============================================
    // バックアップ出力
    // ============================================
    private async Task ExportBackup()
    {
        backupLoading = true;
        try
        {
            var players = (await supabase.From<Player>().Get()).Models;
            var seasons = (await supabase.From<Season>().Get()).Models;
            var tournaments = (await supabase.From<Tournament>().Get()).Models;
            var seasonPlayers = (await supabase.From<SeasonPlayer>().Get()).Models;
            var decks = (await supabase.From<Deck>().Get()).Models;
            var tournamentDecks = (await supabase.From<TournamentDeck>().Get()).Models;
            var matches = (await supabase.From<Match>().Get()).Models;
            var bannedCards = (await supabase.From<BannedCard>().Get()).Models;

            var backup = new
            {
                Players = players.Select(p => new { p.Id, p.Name, p.CreatedAt }),
                Seasons = seasons.Select(s => new { s.Id, s.Name, s.Status, s.DeckCount, s.RankPoints, s.CreatedAt }),
                Tournaments = tournaments.Select(t => new { t.Id, t.SeasonId, t.Name, t.DeckCount, t.Status, t.CreatedAt }),
                SeasonPlayers = seasonPlayers.Select(sp => new { sp.Id, sp.SeasonId, sp.TournamentId, sp.PlayerId, sp.RemainingDecks, sp.WinCount, sp.LoseCount, sp.Rank, sp.TotalPoints, sp.InitialPoints, sp.CreatedAt }),
                Decks = decks.Select(d => new { d.Id, d.PlayerId, d.Name, d.CreatedAt }),
                TournamentDecks = tournamentDecks.Select(td => new { td.Id, td.SeasonPlayerId, td.DeckId, td.Status, td.CreatedAt }),
                Matches = matches.Select(m => new { m.Id, m.SeasonId, m.TournamentId, m.WinnerPlayerId, m.LoserPlayerId, m.WinnerDeckId, m.LostDeckId, m.FirstPlayerId, m.MatchIndex, m.Memo, m.PlayedAt }),
                BannedCards = bannedCards.Select(b => new { b.Id, b.SeasonId, b.CardName, b.CreatedAt }),
            };

            var json = System.Text.Json.JsonSerializer.Serialize(backup, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = true
            });

            var fileName = $"dm_backup_{DateTime.Now:yyyyMMdd_HHmmss}.json";
            await JS.InvokeVoidAsync("downloadFile", fileName, "application/json", json);
            message = "バックアップをダウンロードしました";
        }
        catch (Exception ex) { errorMessage = ex.Message; }
        finally { backupLoading = false; }
    }

    // ============================================
    // バックアップ復元
    // ============================================
    private class BackupData
    {
        public List<PlayerDto> Players { get; set; } = new();
        public List<SeasonDto> Seasons { get; set; } = new();
        public List<TournamentDto> Tournaments { get; set; } = new();
        public List<SeasonPlayerDto> SeasonPlayers { get; set; } = new();
        public List<DeckDto> Decks { get; set; } = new();
        public List<TournamentDeckDto> TournamentDecks { get; set; } = new();
        public List<MatchDto> Matches { get; set; } = new();
        public List<BannedCardDto> BannedCards { get; set; } = new();
    }

    private record PlayerDto(int Id, string Name, DateTime CreatedAt);
    private record SeasonDto(int Id, string Name, string Status, int DeckCount, string RankPoints, DateTime CreatedAt);
    private record TournamentDto(int Id, int SeasonId, string Name, int DeckCount, string Status, DateTime CreatedAt);
    private record SeasonPlayerDto(int Id, int SeasonId, int TournamentId, int PlayerId, int RemainingDecks, int WinCount, int LoseCount, int? Rank, int TotalPoints, int InitialPoints, DateTime CreatedAt);
    private record DeckDto(int Id, int PlayerId, string Name, DateTime CreatedAt);
    private record TournamentDeckDto(int Id, int SeasonPlayerId, int DeckId, string Status, DateTime CreatedAt);
    private record MatchDto(int Id, int SeasonId, int TournamentId, int WinnerPlayerId, int LoserPlayerId, int WinnerDeckId, int LostDeckId, int? FirstPlayerId, int? MatchIndex, string? Memo, DateTime PlayedAt);
    private record BannedCardDto(int Id, int SeasonId, string CardName, DateTime CreatedAt);

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        importPreview = null;
        errorMessage = null;
        try
        {
            var file = e.File;
            using var stream = file.OpenReadStream(10 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            importPreview = System.Text.Json.JsonSerializer.Deserialize<BackupData>(json,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            StateHasChanged();
        }
        catch (Exception ex) { errorMessage = $"ファイル読み込みエラー: {ex.Message}"; }
    }

    private async Task ImportBackup()
    {
        if (importPreview == null) return;
        importLoading = true;
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(importPreview, new System.Text.Json.JsonSerializerOptions
            {
                WriteIndented = false
            });

            await supabase.Rpc("import_all_data", new { p_json = json });

            importPreview = null;
            message = "復元が完了しました";
            await LoadData();
        }
        catch (Exception ex) { errorMessage = $"復元エラー: {ex.Message}"; }
        finally { importLoading = false; }
    }

    // ============================================
    // 通常管理
    // ============================================
    private async Task CreateSeason()
    {
        try
        {
            var points = ParseRankPoints(newRankPoints);
            await SeasonService.CreateAsync(newSeasonName, points);
            message = $"シーズン「{newSeasonName}」を作成しました";
            newSeasonName = ""; newRankPoints = "3,1,0";
            await LoadData();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task UpdateRankPoints()
    {
        try
        {
            var points = ParseRankPoints(editRankPoints);
            var json = System.Text.Json.JsonSerializer.Serialize(points);
            await SeasonService.UpdateRankPointsAsync(activeSeason!.Id, json);
            message = "勝ち点設定を更新しました";
            await LoadData();
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task FinishSeason()
    {
        try { await SeasonService.FinishAsync(activeSeason!.Id); message = "シーズンを終了しました"; await LoadData(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task CreateTournament()
    {
        try { await TournamentService.CreateAsync(activeSeason!.Id, newTournamentName, newTournamentDeckCount); message = $"大会「{newTournamentName}」を作成しました"; newTournamentName = ""; await LoadData(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task FinishTournament()
    {
        try { var standings = await PlayerService.GetTournamentStandingsAsync(activeTournament!.Id); await TournamentService.FinishAsync(activeTournament.Id, standings); message = "大会を終了しました"; await LoadData(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task JoinTournament(int playerId)
    {
        int initialPoints = initialPointsMap.GetValueOrDefault(playerId, 0);
        try { await PlayerService.JoinTournamentAsync(activeSeason!.Id, activeTournament!.Id, playerId, activeTournament.DeckCount, initialPoints); message = "参加登録しました"; await LoadData(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task CreatePlayer()
    {
        try { await PlayerService.CreateAsync(newPlayerName); message = $"プレイヤー「{newPlayerName}」を追加しました"; newPlayerName = ""; allPlayers = await PlayerService.GetAllAsync(); }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task AddBannedCard()
    {
        try
        {
            await BannedCardService.AddAsync(activeSeason!.Id, newCardName.Trim());
            message = $"「{newCardName}」を禁止カードに追加しました";
            newCardName = "";
            bannedCards = await BannedCardService.GetBySeasonAsync(activeSeason.Id);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

    private async Task DeleteBannedCard(int id)
    {
        try
        {
            await BannedCardService.DeleteAsync(id);
            message = "禁止カードを削除しました";
            bannedCards = await BannedCardService.GetBySeasonAsync(activeSeason!.Id);
        }
        catch (Exception ex) { errorMessage = ex.Message; }
    }

}
