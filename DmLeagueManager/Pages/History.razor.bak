@page "/history"
@using DmLeagueManager.Models
@using DmLeagueManager.Services
@inject SeasonService SeasonService
@inject PlayerService PlayerService

<PageTitle>シーズン履歴 - DM League Manager</PageTitle>

<div class="section-title">過去のシーズン</div>

@if (loading)
{
    <div class="loading">読み込み中...</div>
}
else
{
    @foreach (var season in finishedSeasons)
    {
        var sps = standingsMap.GetValueOrDefault(season.Id, new());

        <div class="standings-card" style="margin-bottom:12px">
            <div class="standings-header">
                <div class="standings-title">@season.Name</div>
                <div class="match-count">終了済み</div>
            </div>
            @{ int rank = 1; }
            @foreach (var sp in sps.OrderBy(s => s.Rank ?? 99))
            {
                string rankClass = rank switch { 1 => "rank-num gold", 2 => "rank-num silver", _ => "rank-num eliminated-rank" };
                <div class="player-row @(sp.IsEliminated ? "eliminated" : "")">
                    <div class="@rankClass">@rank</div>
                    <div class="player-info">
                        <div class="player-name">@sp.Player?.Name</div>
                    </div>
                    <div class="player-stats">
                        <span class="text-win">@sp.WinCount 勝</span> / <span class="text-lose">@sp.LoseCount 敗</span>
                    </div>
                    <div class="player-points">@sp.TotalPoints<span class="points-label">pt</span></div>
                </div>
                rank++;
            }
        </div>
    }

    @if (!finishedSeasons.Any())
    {
        <div class="empty-state">過去のシーズンはありません</div>
    }
}

@code {
    private List<Season> finishedSeasons = new();
    private Dictionary<int, List<SeasonPlayer>> standingsMap = new();
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        var allSeasons = await SeasonService.GetAllAsync();
        finishedSeasons = allSeasons.Where(s => s.Status == "finished").ToList();

        foreach (var season in finishedSeasons)
        {
            standingsMap[season.Id] = await PlayerService.GetSeasonStandingsAsync(season.Id);
        }
        loading = false;
    }
}
