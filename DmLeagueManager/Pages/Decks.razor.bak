@page "/decks"
@using DmLeagueManager.Models
@using DmLeagueManager.Services
@inject SeasonService SeasonService
@inject TournamentService TournamentService
@inject PlayerService PlayerService
@inject DeckService DeckService
@inject MatchService MatchService
@inject DeckStatsService DeckStatsService

<PageTitle>デッキ - DM League Manager</PageTitle>

@if (loading)
{
    <div class="loading">読み込み中...</div>
}
else if (!seasonPlayers.Any())
{
    <div class="empty-state">参加プレイヤーがいません</div>
}
else
{
    <!-- プレイヤー切り替え -->
    <div class="player-tabs">
        @foreach (var sp in seasonPlayers)
        {
            <button class="player-tab-btn @(selectedSeasonPlayerId == sp.Id ? "active" : "")"
                    @onclick="() => SelectPlayer(sp)">
                @sp.Player?.Name
            </button>
        }
    </div>

    @if (selectedSp != null)
    {
        <div class="section-title">@selectedSp.Player?.Name のデッキ（残 @selectedSp.RemainingDecks デッキ）</div>

        <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:20px;">
            @foreach (var deck in allDecks)
            {
                bool isExpanded = expandedDeckId == deck.Id;
                var stats = deckStatsMap.GetValueOrDefault(deck.Id);

                <div style="background:var(--surface); border:1px solid @(deck.IsActive ? "rgba(46,204,113,0.3)" : "var(--border)"); border-radius:10px; overflow:hidden;">

                    <!-- ヘッダー -->
                    <div style="padding:12px 14px; display:flex; align-items:center; gap:12px; cursor:pointer;"
                         @onclick="() => ToggleDeck(deck.Id)">
                        <div style="font-size:18px;">@(deck.IsActive ? "🟢" : "💀")</div>
                        <div style="flex:1;">
                            <div style="font-weight:700; font-size:14px; color:@(deck.IsActive ? "var(--text)" : "var(--text-dim)")">
                                @deck.Name
                            </div>
                            @if (stats != null)
                            {
                                <div style="font-size:11px; color:var(--text-dim); margin-top:2px;">
                                    @stats.WinCount 勝 @stats.LoseCount 敗
                                    @if (stats.TotalGames > 0)
                                    {
                                        <span style="color:@(stats.WinRate >= 50 ? "var(--win)" : "var(--lose)"); margin-left:6px; font-weight:700;">
                                            勝率 @stats.WinRate%
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                        @if (stats != null && stats.TotalGames > 0)
                        {
                            <div style="width:60px;">
                                <div style="background:var(--surface2); border-radius:4px; height:6px; overflow:hidden;">
                                    <div style="width:@(stats.WinRate)%; background:@(stats.WinRate >= 50 ? "var(--win)" : "var(--lose)"); height:100%;"></div>
                                </div>
                            </div>
                        }
                        <div style="color:var(--text-dim); font-size:12px;">@(isExpanded ? "▲" : "▼")</div>
                    </div>

                    <!-- 展開詳細 -->
                    @if (isExpanded && stats != null)
                    {
                        <div style="border-top:1px solid var(--border); padding:12px 14px; background:var(--surface2);">
                            @if (stats.WinRecords.Any())
                            {
                                <div style="font-size:11px; color:var(--win); font-weight:700; margin-bottom:6px; letter-spacing:0.1em;">
                                    ✅ 勝った試合（@stats.WinCount 回）
                                </div>
                                @foreach (var r in stats.WinRecords.OrderByDescending(x => x.PlayedAt))
                                {
                                    <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 10px; background:rgba(39,174,96,0.08); border:1px solid rgba(39,174,96,0.2); border-radius:6px; margin-bottom:4px;">
                                        <div style="font-size:12px;">
                                            <span style="color:var(--text-dim)">@r.OpponentPlayerName</span>
                                            <span style="color:var(--text); margin-left:4px; font-weight:700;">@r.OpponentDeckName</span>
                                        </div>
                                        <div style="font-size:10px; color:var(--text-dim);">@r.PlayedAt.ToLocalTime().ToString("MM/dd")</div>
                                    </div>
                                }
                            }
                            @if (stats.LoseRecords.Any())
                            {
                                <div style="font-size:11px; color:var(--lose); font-weight:700; margin-bottom:6px; margin-top:@(stats.WinRecords.Any() ? "10px" : "0"); letter-spacing:0.1em;">
                                    💀 負けた試合（@stats.LoseCount 回）
                                </div>
                                @foreach (var r in stats.LoseRecords.OrderByDescending(x => x.PlayedAt))
                                {
                                    <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 10px; background:rgba(192,57,43,0.08); border:1px solid rgba(192,57,43,0.2); border-radius:6px; margin-bottom:4px;">
                                        <div style="font-size:12px;">
                                            <span style="color:var(--text-dim)">@r.OpponentPlayerName</span>
                                            <span style="color:var(--text); margin-left:4px; font-weight:700;">@r.OpponentDeckName</span>
                                        </div>
                                        <div style="font-size:10px; color:var(--text-dim);">@r.PlayedAt.ToLocalTime().ToString("MM/dd")</div>
                                    </div>
                                }
                            }
                            @if (!stats.WinRecords.Any() && !stats.LoseRecords.Any())
                            {
                                <div style="font-size:12px; color:var(--text-dim); text-align:center; padding:8px;">
                                    まだ試合記録がありません
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    private List<SeasonPlayer> seasonPlayers = new();
    private SeasonPlayer? selectedSp;
    private int selectedSeasonPlayerId = 0;
    private List<Deck> allDecks = new();
    private Dictionary<int, DeckStats> deckStatsMap = new();
    private int expandedDeckId = 0;
    private bool loading = true;

    private List<Match> allMatches = new();
    private Dictionary<int, Deck> deckMap = new();
    private Dictionary<int, Player> playerMap = new();
    private Dictionary<int, SeasonPlayer> seasonPlayerMap = new();

    protected override async Task OnInitializedAsync()
    {
        var season = await SeasonService.GetActiveAsync();
        if (season != null)
        {
            var tournaments = await TournamentService.GetBySeasonAsync(season.Id);
            var players = await PlayerService.GetAllAsync();
            playerMap = players.ToDictionary(p => p.Id);

            foreach (var t in tournaments)
            {
                var matches = await MatchService.GetTournamentMatchesAsync(t.Id);
                allMatches.AddRange(matches);
            }

            var activeTournament = tournaments.FirstOrDefault(t => t.IsActive);
            if (activeTournament != null)
            {
                seasonPlayers = await PlayerService.GetTournamentStandingsAsync(activeTournament.Id);
                foreach (var sp in seasonPlayers)
                    seasonPlayerMap[sp.PlayerId] = sp;

                if (seasonPlayers.Any())
                    await SelectPlayer(seasonPlayers.First());
            }
        }
        loading = false;
    }

    private async Task SelectPlayer(SeasonPlayer sp)
    {
        selectedSp = sp;
        selectedSeasonPlayerId = sp.Id;
        expandedDeckId = 0;
        allDecks = await DeckService.GetBySeasonPlayerAsync(sp.Id);

        // デッキマップ再構築（対戦相手のデッキ名表示用）
        deckMap.Clear();
        foreach (var d in allDecks) deckMap[d.Id] = d;

        foreach (var other in seasonPlayers.Where(x => x.Id != sp.Id))
        {
            var otherDecks = await DeckService.GetBySeasonPlayerAsync(other.Id);
            foreach (var d in otherDecks) if (!deckMap.ContainsKey(d.Id)) deckMap[d.Id] = d;
        }

        // 統計計算
        deckStatsMap.Clear();
        foreach (var deck in allDecks)
        {
            deckStatsMap[deck.Id] = await DeckStatsService.GetDeckStatsAsync(
                deck.Id, allMatches, deckMap, playerMap, seasonPlayerMap);
        }
    }

    private void ToggleDeck(int deckId)
    {
        expandedDeckId = expandedDeckId == deckId ? 0 : deckId;
    }
}
