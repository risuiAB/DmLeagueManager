@page "/decks"
@using DmLeagueManager.Models
@using DmLeagueManager.Services
@inject SeasonService SeasonService
@inject TournamentService TournamentService
@inject PlayerService PlayerService
@inject DeckService DeckService
@inject MatchService MatchService
@inject DeckStatsService DeckStatsService

<PageTitle>デッキ - DM League Manager</PageTitle>

@if (loading)
{
    <div class="loading">読み込み中...</div>
}
else if (!allPlayers.Any())
{
    <div class="empty-state">参加プレイヤーがいません</div>
}
else
{
    <!-- プレイヤー切り替え -->
    <div class="player-tabs">
        @foreach (var p in allPlayers)
        {
            <button class="player-tab-btn @(selectedPlayerId == p.Id ? "active" : "")"
                    @onclick="() => SelectPlayer(p.Id)">
                @p.Name
            </button>
        }
    </div>

    <!-- シーズン/大会フィルター -->
    <div style="margin-bottom:16px;">
        <div class="form-label">期間フィルター</div>
        <div style="display:flex; flex-direction:column; gap:6px;">
            <button class="filter-btn @(selectedFilter == "all" ? "active" : "")"
                    @onclick='() => ApplyFilter("all", 0, 0)'>
                📊 全期間
            </button>
            @foreach (var season in allSeasons)
            {
                <button class="filter-btn @(selectedFilter == $"season_{season.Id}" ? "active" : "")"
                        @onclick="@(() => ApplyFilter($"season_{season.Id}", season.Id, 0))">
                    📅 @season.Name
                </button>
                @foreach (var t in tournamentMap.GetValueOrDefault(season.Id, new()))
                {
                    <button class="filter-btn sub @(selectedFilter == $"tournament_{t.Id}" ? "active" : "")"
                            @onclick="@(() => ApplyFilter($"tournament_{t.Id}", season.Id, t.Id))">
                        🏆 @t.Name @(t.IsActive ? "🔴" : "")
                    </button>
                }
            }
        </div>
    </div>

    <!-- デッキ一覧 -->
    @if (selectedPlayerId > 0)
    {
        <div class="section-title">デッキ統計</div>

        @if (!filteredDecks.Any())
        {
            <div class="empty-state">この期間のデッキ記録がありません</div>
        }
        else
        {
            <div style="display:flex; flex-direction:column; gap:8px; margin-bottom:100px;">
                @foreach (var (deck, isActive) in filteredDecks)
                {
                    bool isExpanded = expandedDeckId == deck.Id;
                    var stats = deckStatsMap.GetValueOrDefault(deck.Id);

                    <div style="background:var(--surface); border:1px solid @(isActive ? "rgba(46,204,113,0.3)" : "var(--border)"); border-radius:10px; overflow:hidden;">
                        <div style="padding:12px 14px; display:flex; align-items:center; gap:12px; cursor:pointer;"
                             @onclick="() => ToggleDeck(deck.Id)">
                            <div style="font-size:18px;">@(isActive ? "🟢" : "💀")</div>
                            <div style="flex:1;">
                                <div style="font-weight:700; font-size:14px; color:@(isActive ? "var(--text)" : "var(--text-dim)")">
                                    @deck.Name
                                </div>
                                @if (stats != null)
                                {
                                    <div style="font-size:11px; color:var(--text-dim); margin-top:2px;">
                                        @stats.WinCount 勝 @stats.LoseCount 敗
                                        @if (stats.TotalGames > 0)
                                        {
                                            <span style="color:@(stats.WinRate >= 50 ? "var(--win)" : "var(--lose)"); margin-left:6px; font-weight:700;">
                                                勝率 @stats.WinRate%
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="margin-left:6px;">試合なし</span>
                                        }
                                    </div>
                                }
                            </div>
                            @if (stats != null && stats.TotalGames > 0)
                            {
                                <div style="width:60px;">
                                    <div style="background:var(--surface2); border-radius:4px; height:6px; overflow:hidden;">
                                        <div style="width:@(stats.WinRate)%; background:@(stats.WinRate >= 50 ? "var(--win)" : "var(--lose)"); height:100%;"></div>
                                    </div>
                                </div>
                            }
                            <div style="color:var(--text-dim); font-size:12px;">@(isExpanded ? "▲" : "▼")</div>
                        </div>

                        @if (isExpanded && stats != null)
                        {
                            <div style="border-top:1px solid var(--border); padding:12px 14px; background:var(--surface2);">
                                @if (stats.WinRecords.Any())
                                {
                                    <div style="font-size:11px; color:var(--win); font-weight:700; margin-bottom:6px; letter-spacing:0.1em;">
                                        ✅ 勝った試合（@stats.WinCount 回）
                                    </div>
                                    @foreach (var r in stats.WinRecords.OrderByDescending(x => x.PlayedAt))
                                    {
                                        <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 10px; background:rgba(39,174,96,0.08); border:1px solid rgba(39,174,96,0.2); border-radius:6px; margin-bottom:4px;">
                                            <div style="font-size:12px;">
                                                <span style="color:var(--text-dim)">@r.OpponentPlayerName</span>
                                                <span style="color:var(--text); margin-left:4px; font-weight:700;">@r.OpponentDeckName</span>
                                            </div>
                                            <div style="font-size:10px; color:var(--text-dim);">@r.PlayedAt.AddHours(9).ToString("MM/dd")</div>
                                        </div>
                                    }
                                }
                                @if (stats.LoseRecords.Any())
                                {
                                    <div style="font-size:11px; color:var(--lose); font-weight:700; margin-bottom:6px; margin-top:@(stats.WinRecords.Any() ? "10px" : "0"); letter-spacing:0.1em;">
                                        💀 負けた試合（@stats.LoseCount 回）
                                    </div>
                                    @foreach (var r in stats.LoseRecords.OrderByDescending(x => x.PlayedAt))
                                    {
                                        <div style="display:flex; justify-content:space-between; align-items:center; padding:6px 10px; background:rgba(192,57,43,0.08); border:1px solid rgba(192,57,43,0.2); border-radius:6px; margin-bottom:4px;">
                                            <div style="font-size:12px;">
                                                <span style="color:var(--text-dim)">@r.OpponentPlayerName</span>
                                                <span style="color:var(--text); margin-left:4px; font-weight:700;">@r.OpponentDeckName</span>
                                            </div>
                                            <div style="font-size:10px; color:var(--text-dim);">@r.PlayedAt.AddHours(9).ToString("MM/dd")</div>
                                        </div>
                                    }
                                }
                                @if (!stats.WinRecords.Any() && !stats.LoseRecords.Any())
                                {
                                    <div style="font-size:12px; color:var(--text-dim); text-align:center; padding:8px;">
                                        この期間の試合記録がありません
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
}

@code {
    private List<Player> allPlayers = new();
    private List<Season> allSeasons = new();
    private Dictionary<int, List<Tournament>> tournamentMap = new();

    // キャッシュ
    private Dictionary<int, List<Match>> matchesByTournament = new();
    private Dictionary<int, List<Match>> matchesBySeason = new();
    // playerId → (Deck, isActive) のリスト（大会ごとのステータスを保持）
    private Dictionary<int, List<(Deck Deck, int TournamentId, bool IsActive)>> decksByPlayer = new();
    private Dictionary<int, Deck> globalDeckMap = new();
    private Dictionary<int, Player> playerMap = new();

    // 選択状態
    private int selectedPlayerId = 0;
    private string selectedFilter = "all";
    private int selectedSeasonId = 0;
    private int selectedTournamentId = 0;

    // 表示用
    private List<(Deck Deck, bool IsActive)> filteredDecks = new();
    private Dictionary<int, DeckStats> deckStatsMap = new();
    private int expandedDeckId = 0;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        allPlayers = await PlayerService.GetAllAsync();
        playerMap = allPlayers.ToDictionary(p => p.Id);
        allSeasons = await SeasonService.GetAllAsync();

        foreach (var season in allSeasons)
        {
            var tournaments = await TournamentService.GetBySeasonAsync(season.Id);
            tournamentMap[season.Id] = tournaments;

            var seasonMatches = new List<Match>();
            foreach (var t in tournaments)
            {
                var matches = await MatchService.GetTournamentMatchesAsync(t.Id);
                matchesByTournament[t.Id] = matches;
                seasonMatches.AddRange(matches);

                var standings = await PlayerService.GetTournamentStandingsAsync(t.Id);
                foreach (var sp in standings)
                {
                    // tournament_decksからデッキとステータスを取得
                    var tdPairs = await DeckService.GetTournamentDecksAsync(sp.Id);
                    foreach (var (deck, td) in tdPairs)
                    {
                        globalDeckMap[deck.Id] = deck;
                        if (!decksByPlayer.ContainsKey(sp.PlayerId))
                            decksByPlayer[sp.PlayerId] = new();

                        // 既存エントリがなければ追加
                        if (!decksByPlayer[sp.PlayerId].Any(x => x.Deck.Id == deck.Id && x.TournamentId == t.Id))
                            decksByPlayer[sp.PlayerId].Add((deck, t.Id, td.IsActive));
                    }
                }
            }
            matchesBySeason[season.Id] = seasonMatches;
        }

        if (allPlayers.Any())
        {
            selectedPlayerId = allPlayers.First().Id;
            await RefreshView();
        }
        loading = false;
    }

    private async Task SelectPlayer(int playerId)
    {
        selectedPlayerId = playerId;
        expandedDeckId = 0;
        await RefreshView();
    }

    private async Task ApplyFilter(string filter, int seasonId, int tournamentId)
    {
        selectedFilter = filter;
        selectedSeasonId = seasonId;
        selectedTournamentId = tournamentId;
        expandedDeckId = 0;
        await RefreshView();
    }

    private async Task RefreshView()
    {
        // 対象試合を絞り込む
        List<Match> targetMatches;
        if (selectedFilter == "all")
            targetMatches = matchesByTournament.Values.SelectMany(x => x).ToList();
        else if (selectedFilter.StartsWith("season_"))
            targetMatches = matchesBySeason.GetValueOrDefault(selectedSeasonId, new());
        else
            targetMatches = matchesByTournament.GetValueOrDefault(selectedTournamentId, new());

        // デッキを絞り込む
        var playerDecks = decksByPlayer.GetValueOrDefault(selectedPlayerId, new());

        List<(Deck Deck, bool IsActive)> deckList;

        if (selectedFilter == "all")
        {
            // 全期間: デッキIDで重複除去、最新のステータスを使用
            deckList = playerDecks
                .GroupBy(x => x.Deck.Id)
                .Select(g => (g.First().Deck, g.OrderByDescending(x => x.TournamentId).First().IsActive))
                .ToList();
        }
        else if (selectedFilter.StartsWith("season_"))
        {
            var seasonTournamentIds = tournamentMap.GetValueOrDefault(selectedSeasonId, new())
                .Select(t => t.Id).ToHashSet();
            deckList = playerDecks
                .Where(x => seasonTournamentIds.Contains(x.TournamentId))
                .GroupBy(x => x.Deck.Id)
                .Select(g => (g.First().Deck, g.OrderByDescending(x => x.TournamentId).First().IsActive))
                .ToList();
        }
        else
        {
            deckList = playerDecks
                .Where(x => x.TournamentId == selectedTournamentId)
                .GroupBy(x => x.Deck.Id)
                .Select(g => (g.First().Deck, g.First().IsActive))
                .ToList();
        }

        filteredDecks = deckList
            .OrderBy(x => x.IsActive ? 0 : 1)
            .ThenBy(x => x.Deck.Name)
            .ToList();

        // 統計計算
        deckStatsMap.Clear();
        foreach (var (deck, _) in filteredDecks)
        {
            deckStatsMap[deck.Id] = await DeckStatsService.GetDeckStatsAsync(
                deck.Id, targetMatches, globalDeckMap, playerMap);
        }
    }

    private void ToggleDeck(int deckId)
    {
        expandedDeckId = expandedDeckId == deckId ? 0 : deckId;
    }
}
