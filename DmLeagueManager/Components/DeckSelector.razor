@* デッキ選択コンポーネント
   今大会使用済み / プレイヤー全履歴 / 新規入力 を切り替えて選択できる *@

<div class="deck-selector">

    <!-- タブ切り替え -->
    <div class="deck-selector-tabs">
        <button class="deck-tab @(mode == "season" ? "active" : "")" @onclick='() => mode = "season"'>
            今大会
        </button>
        <button class="deck-tab @(mode == "all" ? "active" : "")" @onclick='() => mode = "all"'>
            全履歴
        </button>
        <button class="deck-tab @(mode == "new" ? "active" : "")" @onclick='() => mode = "new"'>
            新規入力
        </button>
    </div>

    <!-- 今大会のデッキ一覧 -->
    @if (mode == "season")
    {
        @if (!TournamentDecks.Any())
        {
            <div class="deck-empty">今大会はまだデッキがありません</div>
        }
        else
        {
            <div class="deck-list">
                @foreach (var (deck, td) in TournamentDecks)
                {
                    bool selectable = td.IsActive || ShowAll;
                    <div class="deck-select-item @(SelectedDeckId == deck.Id ? "selected" : "")"
                         style="@(!selectable ? "opacity:0.5; cursor:not-allowed;" : "")"
                         @onclick="() => { if(selectable) SelectDeck(deck.Id); }">
                        <span>@deck.Name</span>
                        <span style="font-size:11px; color:@(td.IsActive ? "var(--win)" : "var(--lose)")">
                            @(td.IsActive ? "使用可" : "消滅済")
                        </span>
                    </div>
                }
            </div>
        }
    }

    <!-- 全履歴デッキ一覧 -->
    @if (mode == "all")
    {
        @if (!AllDecks.Any())
        {
            <div class="deck-empty">デッキ履歴がありません</div>
        }
        else
        {
            <div class="deck-list">
                @foreach (var deck in AllDecks)
                {
                    // 今大会で消滅済みのデッキは選択不可
                    var td = TournamentDecks.FirstOrDefault(x => x.Deck.Id == deck.Id).TournamentDeck;
                    bool isLostInTournament = td != null && !td.IsActive;
                    bool selectable = !isLostInTournament || ShowAll;
                    <div class="deck-select-item @(SelectedDeckId == deck.Id ? "selected" : "")"
                         style="@(!selectable ? "opacity:0.5; cursor:not-allowed;" : "")"
                         @onclick="() => { if(selectable) SelectDeckFromHistory(deck); }">
                        <span>@deck.Name</span>
                        @if (isLostInTournament)
                        {
                            <span style="font-size:11px; color:var(--lose)">消滅済</span>
                        }
                    </div>
                }
            </div>
        }
    }

    <!-- 新規入力 -->
    @if (mode == "new")
    {
        <input class="text-input"
               style="margin-top:8px; margin-bottom:0;"
               placeholder="デッキ名を入力"
               value="@newName"
               @oninput="OnNewNameInput" />
    }

</div>

@code {
    [Parameter] public List<(Deck Deck, TournamentDeck TournamentDeck)> TournamentDecks { get; set; } = new();
    [Parameter] public List<Deck> AllDecks { get; set; } = new();
    [Parameter] public int SelectedDeckId { get; set; }
    [Parameter] public EventCallback<int> OnDeckSelected { get; set; }
    [Parameter] public EventCallback<string> OnNewDeckName { get; set; }
    [Parameter] public EventCallback<Deck> OnDeckAddedToTournament { get; set; }
    [Parameter] public bool ShowAll { get; set; } = false;

    private string mode = "season";
    private string newName = "";

    private async Task SelectDeck(int id)
    {
        await OnDeckSelected.InvokeAsync(id);
        await OnNewDeckName.InvokeAsync("");
    }

    private async Task SelectDeckFromHistory(Deck deck)
    {
        await OnDeckSelected.InvokeAsync(deck.Id);
        await OnNewDeckName.InvokeAsync("");
        await OnDeckAddedToTournament.InvokeAsync(deck);
        mode = "season";
    }

    private async Task OnNewNameInput(ChangeEventArgs e)
    {
        newName = e.Value?.ToString() ?? "";
        await OnDeckSelected.InvokeAsync(0);
        await OnNewDeckName.InvokeAsync(newName);
    }
}
